# ═══════════════════════════════════════
# 启点蓝图 · 环境变量模板
# 
# 用途：列出 2.0 所需的所有环境变量。
# ⚠️ 本文件不含真实值，仅作模板参考。
# ⚠️ 密码、token、密钥不得提交到任何代码仓库。
# ═══════════════════════════════════════

# ── Supabase（后端 / 服务端使用）──
# SUPABASE_URL（前端已配置）
# SUPABASE_SERVICE_ROLE_KEY=             # ❌ 仅服务端，不得进前端
# SUPABASE_ANON_KEY（前端已配置）

# ── DeepSeek AI ──
# DEEPSEEK_API_KEY=                      # ❌ 仅服务端（Supabase Secrets）

# ── 飞书反馈 Webhook ──
# FEISHU_FEEDBACK_WEBHOOK_URL=           # ❌ 仅服务端环境变量

# ── 支付（未来）──
# WECHAT_PAY_API_KEY=                    # ❌ 仅服务端
# WECHAT_PAY_MCH_ID=
# ALIPAY_APP_PRIVATE_KEY=

# ── GitHub（CI/CD）──
# GH_PERSONAL_ACCESS_TOKEN=              # ❌ GitHub Secrets，不入仓库

# ── 数据库 ──
# DATABASE_URL=                          # ❌ 仅服务端
# DATABASE_BACKUP_SCHEDULE=0 0 * * *

# ── 部署 ──
# CLOUDFLARE_API_TOKEN=                  # ❌ GitHub Actions Secrets
# CLOUDFLARE_ACCOUNT_ID=

# ── 日志与监控 ──
# SENTRY_DSN=
# LOG_LEVEL=info

# ── 功能开关 ──
# ALLOW_DEMO_MODE=false                  # 生产环境必须为 false
# ENABLE_ADMIN_PANEL=false               # 安全处置后关闭
